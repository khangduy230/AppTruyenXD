<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ScrollView bao bọc toàn bộ để có thể lướt lên xuống -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 1. Tiêu đề -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thư viện"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <!-- 2. Thanh lọc (3 nút) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã đọc"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Để sau"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tải xuống"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- 3. KHUNG LƯỚI TRUYỆN (Chia 3 cột) -->
            <!-- Dòng 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">

                <!-- Cột 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tên truyện"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tác giả"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Cột 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="6dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Cột 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Dòng 2 (Copy y hệt dòng 1 xuống) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">

                <!-- Cột 1 -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Cột 2 -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginHorizontal="6dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Cột 3 -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>