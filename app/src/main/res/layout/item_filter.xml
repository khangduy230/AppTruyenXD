<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <!-- Thanh kéo (Drag Handle) -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:background="#79747E"
        android:alpha="0.4" />

    <!-- Mục: Sắp xếp theo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Thêm ID để xử lý click -->
        <RelativeLayout
            android:id="@+id/headerSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivSortIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_sort"
                app:tint="#444746" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivSortIcon"
                android:text="Sắp xếp theo"
                android:textColor="#1D1B20"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivToggleSort"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_icon"
                android:padding="8dp"
                android:rotation="0"
                android:src="@drawable/ic_back"
                app:tint="#444746" />
        </RelativeLayout>

        <!-- Khối chứa các option -->
        <LinearLayout
            android:id="@+id/layoutSortOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="4dp">

            <TextView
                android:id="@+id/tvSortAlpha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Bảng chữ cái"
                android:textColor="#1D1B20"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tvSortNewest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Mới nhất"
                android:textColor="#1D1B20"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tvSortRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Đánh giá"
                android:textColor="#1D1B20"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#CAC4D0"
        android:alpha="0.3" />

    <!-- Mục: Thể loại -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/headerGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivCategoryIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_list"
                app:tint="#444746" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivCategoryIcon"
                android:text="Thể loại"
                android:textColor="#1D1B20"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivToggleGenre"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_icon"
                android:padding="8dp"
                android:rotation="0"
                android:src="@drawable/ic_back"
                app:tint="#444746" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutGenreOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="4dp">

            <CheckBox
                android:id="@+id/cbMMB1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MMB1"
                android:textColor="#1D1B20"
                android:textSize="15sp"
                app:buttonTint="#4A5A43" />

            <CheckBox
                android:id="@+id/cbGenreNew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mới nhất"
                android:textColor="#1D1B20"
                android:textSize="15sp"
                app:buttonTint="#4A5A43" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>