<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- DÒNG 1: HEADER (Nút Back + Tiêu đề Cài đặt) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"> <!-- Thêm margin dưới để cách xa phần setting -->

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert" />
        <!-- Tạm thời dùng icon có sẵn của Android cho bạn dễ nhìn, sau này bạn thay bằng icon của bạn -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Cài đặt"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>


    <!-- DÒNG 2: ITEM SETTING (Chế độ ban đêm + Switch) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chế độ ban đêm (Dark Mode)"
            android:textSize="18sp" />

        <Switch
            android:id="@+id/switchDarkMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Bạn có thể copy "DÒNG 2" dán xuống dưới để làm thêm các cài đặt khác (Đổi mật khẩu, Ngôn ngữ, v.v.) -->

</LinearLayout>